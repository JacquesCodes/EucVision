y_label = "Difference in crown area (m2)", fill_col = "#d95f02", ncol = 3)
ggsave(file.path(OUTPUT_DIR, "crown_spacing_differences.png"), p_c_sc_diff,
width = 6.30, height = 3.0, units = "in", dpi = 300)
