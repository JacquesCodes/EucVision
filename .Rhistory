library(tidyverse)
library(patchwork)
# --- Load ---------------------------------------------------------------
nadir   <- read_csv("Crown_Metrics_26_June_2026.csv")
library(tidyverse)
library(patchwork)
# --- Load ---------------------------------------------------------------
nadir   <- read_csv("E:/Remote Sensing Media/31. 26 June 2026/09. Crown Metrics/Crown_Metrics_26_June_2026.csv")
oblique <- read_csv("E:/Remote Sensing Media/31. 26 June 2026 Oblique/09. Crown Metrics/Crown_Metrics_26_June_2026_Oblique.csv")
als     <- read_csv("E:/Remote Sensing Media/31. 30 June 2026 (ALS)/09. Crown Metrics/Crown_Metrics_30_June_2026_(ALS).csv")
# --- Join on unique tree ID ---------------------------------------------
df <- nadir %>%
select(grop_ld, Height_Nadir = Tree_Height) %>%
inner_join(oblique %>% select(grop_ld, Height_Oblique = Tree_Height), by = "grop_ld") %>%
inner_join(als     %>% select(grop_ld, Height_ALS     = Tree_Height), by = "grop_ld") %>%
drop_na()
# --- Metrics helper -------------------------------------------------------
get_metrics <- function(x, y) {
r2   <- cor(x, y)^2
rmse <- sqrt(mean((x - y)^2))
mae  <- mean(abs(x - y))
list(r2 = r2, rmse = rmse, mae = mae)
}
make_plot <- function(data, xcol, ycol, xlab, ylab) {
m <- get_metrics(data[[xcol]], data[[ycol]])
lims <- range(c(data[[xcol]], data[[ycol]]))
ggplot(data, aes(x = .data[[xcol]], y = .data[[ycol]])) +
geom_point(alpha = 0.4, size = 1.5, color = "#2c7fb8") +
geom_abline(slope = 1, intercept = 0, linetype = "dashed", color = "grey40") +
geom_smooth(method = "lm", se = FALSE, color = "#e34a33", linewidth = 0.8) +
coord_equal(xlim = lims, ylim = lims) +
labs(
x = xlab, y = ylab,
title = paste(xlab, "vs", ylab),
subtitle = sprintf("R\u00b2 = %.3f | RMSE = %.3f m | MAE = %.3f m", m$r2, m$rmse, m$mae)
) +
theme_minimal(base_size = 12)
}
p1 <- make_plot(df, "Height_Nadir",   "Height_Oblique", "Nadir Height (m)",   "Oblique Height (m)")
p2 <- make_plot(df, "Height_Nadir",   "Height_ALS",     "Nadir Height (m)",   "ALS Height (m)")
p3 <- make_plot(df, "Height_Oblique", "Height_ALS",     "Oblique Height (m)", "ALS Height (m)")
combined <- p1 + p2 + p3 + plot_layout(ncol = 3)
combined
ggsave("tree_height_comparison.png", combined, width = 15, height = 5, dpi = 300)
