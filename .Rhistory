#   ctg_clipped,
#   csf(sloop_smooth = TRUE,
#       class_threshold = 0.05,
#       cloth_resolution = 1.5,    # 1m node spacing suited for 1x1m plots
#       rigidness = 3,           # Max stiffness prevents canopy sagging
#       time_step = 1)
# )
print("Applying Progressive TIN Densification (PTD)...")
ctg_classified <- classify_ground(ctg_clipped, ptd(20))
packageVersion("lidR")
