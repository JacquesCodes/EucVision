width = 6.30, height = 3.2, units = "in", dpi = 300)
# ── CROWN AREA plots ──────────────────────────────────────────────────────────
p_c_sp_diff <- plot_diffs(sp_diffs_c,
y_label = "Difference in crown area (m2)", fill_col = "#1b9e77", ncol = 3)
