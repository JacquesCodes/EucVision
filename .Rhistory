)
)
# Dynamic Outlier Filtering: Remove anomalous spikes based on flight distributions
master_dataset <- master_dataset %>%
group_by(Date) %>%
mutate(
Flight_99th = quantile(Tree_Height, probs = 0.99, na.rm = TRUE),
