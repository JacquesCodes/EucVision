# Load required libraries
library(dplyr)
library(readr)
library(lubridate)
# 1. Define file paths (Converted backslashes to forward slashes for R)
main_path <- "C:/Users/jakev/Stellenbosch University/JacquesV B.Sc. skripsie M.Sc. project - Documents/Processed Data/EucVision/01. Data analysis/05. 23 March 2026 Heights Compared.csv"
dtm_0_6cm_path <- "E:/Remote Sensing Media/20. 23 March 2026 0.6cm/09. Crown Metrics/Crown_Metrics_23_March_2026_0.6cm.csv"
scf_path <- "C:/Users/jakev/Stellenbosch University/JacquesV B.Sc. skripsie M.Sc. project - Documents/Processed Data/EucVision/01. Data analysis/02. Pre DTM Archive/01. Master dataset CSV (Pre-DTM).csv"
dsm_path <- "C:/Users/jakev/Stellenbosch University/JacquesV B.Sc. skripsie M.Sc. project - Documents/Processed Data/EucVision/01. Data analysis/01. DSM - DTM = CHM/01. Master Dataset_RasterMath.csv"
# 2. Read the datasets
main_df <- read_csv(main_path, show_col_types = FALSE)
dtm_df  <- read_csv(dtm_0_6cm_path, show_col_types = FALSE)
scf_df  <- read_csv(scf_path, show_col_types = FALSE)
dsm_df  <- read_csv(dsm_path, show_col_types = FALSE)
# 3. Standardize dates for the Master datasets
scf_df <- scf_df %>% mutate(Date_Std = dmy(Date))
dsm_df <- dsm_df %>% mutate(Date_Std = dmy(Date))
target_date <- dmy("23-03-2026")
# 4. Process the source files and REMOVE DUPLICATES before joining
# A) Process the Crown Metrics file (No date filtering needed, just rename Cmprtmn)
clean_dtm <- dtm_df %>%
rename(Compartment = Cmprtmn) %>%
arrange(Compartment, Line, Plot, Tree, desc(Tree_Height)) %>%
distinct(Compartment, Line, Plot, Tree, .keep_all = TRUE) %>%
select(Compartment, Line, Plot, Tree, `DTM_0.6cm_Height_m` = Tree_Height)
# B) Process the SCF Master dataset (Requires date filtering)
clean_scf <- scf_df %>%
filter(Date_Std == target_date) %>%
arrange(Compartment, Line, Plot, Tree, desc(Tree_Height)) %>%
distinct(Compartment, Line, Plot, Tree, .keep_all = TRUE) %>%
select(Compartment, Line, Plot, Tree, SCF_Height_m = Tree_Height)
# C) Process the DSM Master dataset (Requires date filtering)
clean_dsm <- dsm_df %>%
filter(Date_Std == target_date) %>%
arrange(Compartment, Line, Plot, Tree, desc(Tree_Height)) %>%
distinct(Compartment, Line, Plot, Tree, .keep_all = TRUE) %>%
select(Compartment, Line, Plot, Tree, DSM_Height_m = Tree_Height)
# 5. Join the data into the Main CSV
main_df <- main_df %>%
# Remove the target columns if they already exist to prevent duplicating column names
select(-any_of(c("DTM_0.6cm_Height_m", "SCF_Height_m", "DSM_Height_m"))) %>%
# Remove any existing duplicates from your main dataset
distinct(Compartment, Line, Plot, Tree, .keep_all = TRUE) %>%
# Join the clean, unique data sequentially
left_join(clean_dtm, by = c("Compartment", "Line", "Plot", "Tree")) %>%
left_join(clean_scf, by = c("Compartment", "Line", "Plot", "Tree")) %>%
left_join(clean_dsm, by = c("Compartment", "Line", "Plot", "Tree"))
# 6. Save the updated dataset back to the Main CSV path
write_csv(main_df, main_path)
print("Merge complete! 23 March 2026 target CSV successfully updated without duplicates.")
