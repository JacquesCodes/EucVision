# 1. Install and load necessary spatial packages
# install.packages(c("sf", "dplyr")) # Run this if you haven't installed them yet
library(sf)
library(dplyr)
# Change this single variable for each new batch!
date_folder <- "17. 02 March 2026"
# 2. Read the Shapefile
# Make sure All Plots.shp, .shx, .dbf, and .prj are in your working directory
trees_sf <- st_read(paste0("E:/Remote Sensing Media/",date_folder,"/09. Tree heights/All Plots.shp"))
# Note: Shapefiles often abbreviate column names. Based on your files,
# "Tree_Height" might be saved as "Tr_Hght". Let's standardize them for the formula.
# Rename columns if necessary so they are easy to call:
# trees_sf <- trees_sf %>% rename(Tree_Height = Tr_Hght)
# 3. Define your competition search radius (in meters)
# This dictates how far out a tree is considered a "competitor"
search_radius <- 8.0  # Adjust this value based on your specific stand dynamics
# 4. Calculate a pairwise distance matrix between all trees
dist_matrix <- st_distance(trees_sf)
dist_matrix <- as.numeric(dist_matrix) # Convert to standard numeric format
dim(dist_matrix) <- c(nrow(trees_sf), nrow(trees_sf)) # Reshape into a square matrix
# 5. Initialize an empty vector to store our new Competition Index (CI) values
ci_values <- numeric(nrow(trees_sf))
# 6. Loop through each tree (Subject Tree) to calculate the index
for (i in 1:nrow(trees_sf)) {
# Extract Subject Tree (s) variables
CPA_s <- trees_sf$Area[i]
H_s   <- trees_sf$Tree_Height[i]
# Find indices of Competitor Trees (c)
# Must be within the search radius AND greater than 0 distance (to exclude the subject tree itself)
comp_indices <- which(dist_matrix[i, ] <= search_radius & dist_matrix[i, ] > 0)
# If competitors exist, calculate the index
if (length(comp_indices) > 0) {
# Extract Competitor Tree (c) variables
CPA_c   <- trees_sf$Area[comp_indices]
H_c     <- trees_sf$Tree_Height[comp_indices]
Dist_sc <- dist_matrix[i, comp_indices]
# Safety check: avoid division by zero if a tree is recorded with 0 height or 0 area
if (is.na(CPA_s) || is.na(H_s) || CPA_s <= 0 || H_s <= 0) {
ci_values[i] <- NA
} else {
# THE FORMULA: sum((CPA_c * H_c) / (CPA_s * H_s * Dist_sc))
competition_terms <- (CPA_c * H_c) / (CPA_s * H_s * Dist_sc)
ci_values[i] <- sum(competition_terms, na.rm = TRUE)
}
} else {
# If no trees are within the search radius, competition is zero
ci_values[i] <- 0
}
}
# 1. Install and load necessary spatial packages
# install.packages(c("sf", "dplyr")) # Run this if you haven't installed them yet
library(sf)
library(dplyr)
# Change this single variable for each new batch!
date_folder <- "17. 02 March 2026"
# 2. Read the Shapefile
# Make sure All Plots.shp, .shx, .dbf, and .prj are in your working directory
trees_sf <- st_read(paste0("E:/Remote Sensing Media/",date_folder,"/09. Tree heights/All Plots.shp"))
# 3. BULLETPROOFING: Force variables to numeric and use the correct Shapefile column names
# Based on your .dbf file, Tree_Height was abbreviated to Tr_Hght.
trees_sf$Area_Num <- as.numeric(trees_sf$Area)
trees_sf$Height_Num <- as.numeric(trees_sf$Tr_Hght)
# 4. Define your competition search radius (in meters)
# This dictates how far out a tree is considered a "competitor"
search_radius <- 8.0  # Adjust this value based on your specific stand dynamics
# 5. Calculate a pairwise distance matrix between all trees
dist_matrix <- st_distance(trees_sf)
dist_matrix <- as.numeric(dist_matrix) # Convert to standard numeric format
dim(dist_matrix) <- c(nrow(trees_sf), nrow(trees_sf)) # Reshape into a square matrix
# 6. Initialize an empty vector to store our new Competition Index (CI) values
ci_values <- numeric(nrow(trees_sf))
# 7. Loop through each tree (Subject Tree) to calculate the index
for (i in 1:nrow(trees_sf)) {
# Extract Subject Tree (s) variables using the sanitized numeric columns
CPA_s <- trees_sf$Area_Num[i]
H_s   <- trees_sf$Height_Num[i]
# Find indices of Competitor Trees (c)
# Must be within the search radius AND greater than 0 distance (to exclude the subject tree itself)
comp_indices <- which(dist_matrix[i, ] <= search_radius & dist_matrix[i, ] > 0)
# If competitors exist, calculate the index
if (length(comp_indices) > 0) {
# Extract Competitor Tree (c) variables
CPA_c   <- trees_sf$Area_Num[comp_indices]
H_c     <- trees_sf$Height_Num[comp_indices]
Dist_sc <- dist_matrix[i, comp_indices]
# THE FIX: isTRUE() guarantees a safe TRUE/FALSE output.
# If CPA_s or H_s is NA, NULL, or 0, it safely skips the math instead of crashing.
if (isTRUE(CPA_s > 0) && isTRUE(H_s > 0)) {
# We also need to filter out any competitors that might have NA or 0 values
valid_comps <- which(CPA_c > 0 & H_c > 0)
if (length(valid_comps) > 0) {
# THE FORMULA: sum((CPA_c * H_c) / (CPA_s * H_s * Dist_sc))
competition_terms <- (CPA_c[valid_comps] * H_c[valid_comps]) / (CPA_s * H_s * Dist_sc[valid_comps])
ci_values[i] <- sum(competition_terms, na.rm = TRUE)
} else {
ci_values[i] <- 0 # Competitors exist, but they have invalid heights/areas
}
} else {
# If the subject tree itself has missing data, we can't calculate its index
ci_values[i] <- NA
}
} else {
# If no trees are within the search radius, competition is zero
ci_values[i] <- 0
}
}
# 8. Append the calculated index back to our spatial dataset
trees_sf$Castagneri_CI <- ci_values
# 9. Export the results to a clean CSV for analysis (drops the heavy geometry data)
final_df <- st_drop_geometry(trees_sf)
write.csv(final_df, paste0("E:/Remote Sensing Media/",date_folder,"/10. Competition indices/All_Plots_with_Competition_Index.csv"), row.names = FALSE)
print("Competition Index calculated and saved successfully! No more NA logical errors.")
# 1. Load necessary visualization libraries
# install.packages(c("ggplot2", "viridis")) # Run if needed
library(ggplot2)
library(sf)
library(dplyr)
library(viridis) # For colorblind-friendly, scientifically accurate color scales
# (Assuming 'trees_sf' is still in your environment from the previous script)
# If you are starting fresh, you would read the shapefile and merge your new CSV here.
# ==========================================
# MAP 1: Detailed View of a Single Plot
# ==========================================
# Filter for a single plot (Using the 'Plt_shp' column based on your CSV snippet)
single_plot_sf <- trees_sf %>% filter(Plt_shp == "Plot 01")
p1 <- ggplot(data = single_plot_sf) +
# Map color to Competition Index, and point size to the tree's Crown Area
geom_sf(aes(color = Castagneri_CI, size = Area), alpha = 0.85) +
# Use the 'magma' color scale (Low competition = dark purple, High = bright yellow)
scale_color_viridis_c(option = "magma", name = "Competition\nIndex (CI)") +
# Adjust point sizes so they look proportionate to crowns
scale_size_continuous(range = c(2, 8), name = "Crown Area (m²)") +
labs(
title = "Spatial Competition Map: Plot 01",
subtitle = "Brighter colors indicate higher competition stress; Larger circles indicate larger crowns.",
x = "Longitude / Easting",
y = "Latitude / Northing"
) +
theme_minimal() +
theme(
plot.title = element_text(face = "bold", size = 16),
legend.position = "right"
)
# Display the single plot map
print(p1)
# ggsave("Plot_01_Competition_Map.png", plot = p1, width = 10, height = 8, dpi = 300)
# ==========================================
# MAP 2: Grid Comparison of Multiple Plots
# ==========================================
# Let's select 4 plots to compare (Adjust these names based on your actual data)
target_plots <- c("Plot 01", "Plot 02", "Plot 74", "Plot 75")
multi_plot_sf <- trees_sf %>% filter(Plt_shp %in% target_plots)
p2 <- ggplot(data = multi_plot_sf) +
geom_sf(aes(color = Castagneri_CI, size = Area), alpha = 0.8) +
scale_color_viridis_c(option = "viridis", name = "CI") +
scale_size_continuous(range = c(1, 5), guide = "none") + # Hide size legend to save space
# Facet wrap splits the map into individual mini-maps based on the Plot name
# scales = "free" ensures each map zooms in on its own coordinates!
facet_wrap(~ Plt_shp, scales = "free") +
labs(
title = "Competition Index Across Different Plots",
subtitle = "Assessing stand density and spatial distribution"
) +
theme_minimal() +
theme(
strip.text = element_text(face = "bold", size = 12),
axis.text = element_blank(), # Hide coordinates on the grid for a cleaner look
axis.ticks = element_blank()
)
# Display the multi-plot grid
print(p2)
