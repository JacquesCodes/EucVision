p_r_sp_diff <- plot_diffs(sp_diffs_r,
y_label = "Difference in CA:H ratio (m2 m-1)", fill_col = "#6a3d9a", ncol = 3)
ggsave(file.path(OUTPUT_DIR, "cah_species_differences.png"), p_r_sp_diff,
