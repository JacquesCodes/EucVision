MinimumTreeHeight <- 0.3
lmf_alogirthm <- lmf(ws = f, hmin = MinimumTreeHeight, shape = "circular")
# Identify tree tops
ttops <- locate_trees(las = nlas, alogirthm = lmf_alogirthm)
