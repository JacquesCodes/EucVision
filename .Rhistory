library(lidR)
library(RCSF)
library(RMCC)
library(gstat)
library(sf)
library(tictoc)
library(geometry)
library(dplyr)
library(future)
library(terra)
library(rgl)
library(ggplot2)
library(ggspatial)
library(tidyterra)
library(patchwork) # <-- ADDED: For side-by-side ggplot arrangement
# Change this single variable for each new batch!
date_folder <- "19. 16 March 2026"
# Extract the date part by removing the leading folder number, dot, and space
file_date <- sub("^\\d+\\.\\s*", "", date_folder)
# Replace spaces with underscores for safer file naming conventions
file_date_safe <- gsub(" ", "_", file_date)
# My path to the remote sensing dataset
myPath <- paste0("E:/Remote Sensing Media/",date_folder,"/")
# Plot number
Number <- 9
# Dynamically construct the single-date file names
name_clipped <- paste0("Plot_", Number, "_", file_date_safe)
name_classified <- paste0(name_clipped, "_classified")
name_normalised <- paste0(name_classified, "_normalised")
name_chm <- paste0(name_normalised, "_chm")
# Build the full file paths with Title Case directories
path_normalised <- paste0(myPath, "06. Point Clouds Normalised/", name_normalised, ".las")
path_chm <- paste0(myPath, "07. Canopy Height Models/", name_chm, ".tif")
# --- Safely Read in the Data ---
if (file.exists(path_normalised)) {
las_normalised <- readLAS(path_normalised)
message("Loaded: ", name_normalised, ".las")
} else {
message("Skipped: Could not find folder or file for 06. Point Clouds Normalised")
las_normalised <- NULL
}
if (file.exists(path_chm)) {
las_chm <- rast(path_chm)
# Filter out the rogue photogrammetry noise
las_chm[las_chm > 15] <- NA  # Replace 15 with your realistic upper threshold
las_chm[las_chm < 0] <- 0    # Optional: Cleans up any sub-surface negative noise
# --- ADDED: Smooth the CHM ---
# Define the moving window 'w' (A 3x3 matrix is standard for basic smoothing)
w <- matrix(1, nrow = 3, ncol = 3)
# Apply the focal smoothing function to the filtered CHM
smoothed_chm <- terra::focal(las_chm, w = w, fun = max, na.rm = TRUE)
message("Loaded and smoothed: ", name_chm, ".tif")
} else {
message("Skipped: Could not find folder or file for 07. Canopy Height Models")
las_chm <- NULL
smoothed_chm <- NULL # Ensure this is null if the file didn't load
}
# --- Plotting Section ---
# Plot normalised las (Removed "axis = TRUE" to prevent the warning message!)
# if (!is.null(las_normalised)) {
#   plot(las_normalised, color = "RGB", size = 2, bg = "white")
#   plot(las_normalised, size = 2, bg = "white")
# }
# Only generate the maps if the data was successfully loaded
if (!is.null(smoothed_chm) && !is.null(las_chm)) {
# 1. Create the RAW CHM Map
chm_map_raw <- ggplot() +
geom_spatraster(data = las_chm) +
scale_fill_viridis_c(
name = "Canopy Height (m)",
option = "viridis",
na.value = "transparent"
) +
annotation_scale(
location = "br",
width_hint = 0.4,
text_cex = 0.8
) +
annotation_north_arrow(
location = "tr",
which_north = "false",
style = north_arrow_fancy_orienteering()
) +
labs(
title = "Raw Canopy Height Model",
subtitle = paste0("Plot ",Number," - ",file_date),
x = "Longitude",
y = "Latitude"
) +
coord_sf() +
theme_minimal() +
theme(
legend.position = "right",
panel.grid.major = element_line(color = "gray90", linetype = "dashed"),
axis.text.x = element_text(angle = 45, hjust = 1),
plot.margin = margin(t = 0.5, r = 0.5, b = 0.5, l = 0.5, unit = "in")
)
# 2. Create the SMOOTHED CHM Map
chm_map_smoothed <- ggplot() +
geom_spatraster(data = smoothed_chm) +
scale_fill_viridis_c(
name = "Canopy Height (m)",
option = "viridis",
na.value = "transparent"
) +
annotation_scale(
location = "br",
width_hint = 0.4,
text_cex = 0.8
) +
# Dropping the north arrow on the second plot to avoid clutter,
# but keeping the scale bar.
labs(
title = "Smoothed Canopy Height Model",
subtitle = paste0("Plot ",Number," - ",file_date),
x = "Longitude",
y = "" # Dropping Y axis label for the second plot so it sits cleaner next to the first
) +
coord_sf() +
theme_minimal() +
theme(
legend.position = "right",
panel.grid.major = element_line(color = "gray90", linetype = "dashed"),
axis.text.x = element_text(angle = 45, hjust = 1),
plot.margin = margin(t = 0.5, r = 0.5, b = 0.5, l = 0.5, unit = "in")
)
# 3. Combine them side-by-side using patchwork
# The plot_layout(guides = "collect") merges the two identical legends into one
combined_map <- chm_map_raw + chm_map_smoothed + plot_layout(guides = "collect")
# View the combined map
print(combined_map)
}
