# ──────────────────────────────────────────────────────────────────────────────
# EUCVISION: DTM REPROJECTION & RESAMPLING FOR DJI FLIGHTHUB 2
# ──────────────────────────────────────────────────────────────────────────────
# Author: Jacques Vermeulen
# Project: EucVision / EucXylo (https://eucxylo.sun.ac.za/)
# ──────────────────────────────────────────────────────────────────────────────
# Description: Reprojects the baseline DTM from EPSG:2048 (Hartebeesthoek94 /
#              Lo19) to EPSG:4326 (WGS84) and resamples from 0.05m to 0.5m
#              resolution for upload to DJI FlightHub 2.
# ──────────────────────────────────────────────────────────────────────────────
library(terra)
# ──────────────────────────────────────────────────────────────────────────────
# 1. Configuration ####
# ──────────────────────────────────────────────────────────────────────────────
input_path  <- "E:/Remote Sensing Media/00. Baseline DTM/IMPACT_OAL_Baseline_DTM.tif"
output_path <- "E:/Remote Sensing Media/00. Baseline DTM/IMPACT_OAL_Baseline_DTM_WGS84_50cm.tif"
# ──────────────────────────────────────────────────────────────────────────────
# 2. Load & Inspect ####
# ──────────────────────────────────────────────────────────────────────────────
cat("Loading DTM...\n")
dtm <- terra::rast(input_path)
cat("  Source CRS    :", terra::crs(dtm, describe = TRUE)$name, "\n")
cat("  Source resolution (m):", terra::res(dtm), "\n")
cat("  Source dimensions    :", terra::nrow(dtm), "rows x", terra::ncol(dtm), "cols\n")
cat("  File size on disk    :", round(file.size(input_path) / 1e6, 1), "MB\n\n")
# ──────────────────────────────────────────────────────────────────────────────
# 3. Reproject & Resample to WGS84 @ 0.5m ####
# ──────────────────────────────────────────────────────────────────────────────
# terra::project() handles both the CRS transformation and resampling in one
# step when a target resolution is supplied.
#
# method = "bilinear" is correct for continuous elevation surfaces — it
# interpolates smoothly and avoids the staircase artifacts that "near" produces.
# ──────────────────────────────────────────────────────────────────────────────
cat("Reprojecting to EPSG:4326 and resampling to 0.5m...\n")
dtm_wgs84 <- terra::project(
dtm,
"EPSG:4326",
res    = 0.5 / 111320,   # 0.5m expressed in decimal degrees (1 deg ≈ 111,320m)
method = "bilinear"
)
cat("  Target CRS        :", terra::crs(dtm_wgs84, describe = TRUE)$name, "\n")
cat("  Target resolution :", terra::res(dtm_wgs84) * 111320, "m (approx)\n")
cat("  Target dimensions :", terra::nrow(dtm_wgs84), "rows x", terra::ncol(dtm_wgs84), "cols\n\n")
# ──────────────────────────────────────────────────────────────────────────────
# 4. Export ####
# ──────────────────────────────────────────────────────────────────────────────
cat("Writing output...\n")
terra::writeRaster(
dtm_wgs84,
filename  = output_path,
overwrite = TRUE,
gdal      = c("COMPRESS=LZW", "PREDICTOR=3")  # Lossless float compression
)
cat("  Output saved to  :", output_path, "\n")
cat("  Output file size :", round(file.size(output_path) / 1e6, 1), "MB\n\n")
cat("Done. Ready for DJI FlightHub 2 upload.\n")
# ──────────────────────────────────────────────────────────────────────────────
# EUCVISION: DTM REPROJECTION & RESAMPLING FOR DJI FLIGHTHUB 2
# ──────────────────────────────────────────────────────────────────────────────
# Author: Jacques Vermeulen
# Project: EucVision / EucXylo (https://eucxylo.sun.ac.za/)
# ──────────────────────────────────────────────────────────────────────────────
# Description: Reprojects the baseline DTM from EPSG:2048 (Hartebeesthoek94 /
#              Lo19) to EPSG:4326 (WGS84) and resamples from 0.05m to 0.5m
#              resolution for upload to DJI FlightHub 2.
# ──────────────────────────────────────────────────────────────────────────────
library(terra)
# ──────────────────────────────────────────────────────────────────────────────
# 1. Configuration ####
# ──────────────────────────────────────────────────────────────────────────────
input_path  <- "E:/Remote Sensing Media/00. Baseline DTM/IMPACT_OAL_Baseline_DTM.tif"
output_path <- "E:/Remote Sensing Media/00. Baseline DTM/IMPACT_OAL_Baseline_DTM_WGS84_50cm.tif"
# ──────────────────────────────────────────────────────────────────────────────
# 2. Load & Inspect ####
# ──────────────────────────────────────────────────────────────────────────────
cat("Loading DTM...\n")
dtm <- terra::rast(input_path)
cat("  Source CRS    :", terra::crs(dtm, describe = TRUE)$name, "\n")
cat("  Source resolution (m):", terra::res(dtm), "\n")
cat("  Source dimensions    :", terra::nrow(dtm), "rows x", terra::ncol(dtm), "cols\n")
cat("  File size on disk    :", round(file.size(input_path) / 1e6, 1), "MB\n\n")
# ──────────────────────────────────────────────────────────────────────────────
# 3. Reproject & Resample to WGS84 @ 0.5m ####
# ──────────────────────────────────────────────────────────────────────────────
# terra::project() handles both the CRS transformation and resampling in one
# step when a target resolution is supplied.
#
# method = "bilinear" is correct for continuous elevation surfaces — it
# interpolates smoothly and avoids the staircase artifacts that "near" produces.
# ──────────────────────────────────────────────────────────────────────────────
# Force the source CRS explicitly before projecting to avoid axis-order issues
terra::crs(dtm) <- "EPSG:2048"
dtm_wgs84 <- terra::project(
dtm,
"+proj=longlat +datum=WGS84 +no_defs +type=crs",  # Explicit PROJ string
res    = 0.5 / 111320,
method = "bilinear"
)
# Sanity check — Stellenbosch should be roughly 18.8-19.0°E, 34.0-34.2°S
cat("Extent check (should be ~18-19°E, 34°S):\n")
print(terra::ext(dtm_wgs84))
# ──────────────────────────────────────────────────────────────────────────────
# 4. Export ####
# ──────────────────────────────────────────────────────────────────────────────
cat("Writing output...\n")
terra::writeRaster(
dtm_wgs84,
filename  = output_path,
overwrite = TRUE,
gdal      = c("COMPRESS=LZW", "PREDICTOR=3")  # Lossless float compression
)
cat("  Output saved to  :", output_path, "\n")
cat("  Output file size :", round(file.size(output_path) / 1e6, 1), "MB\n\n")
cat("Done. Ready for DJI FlightHub 2 upload.\n")
library(terra)
dtm <- terra::rast("E:/Remote Sensing Media/00. Baseline DTM/IMPACT_OAL_Baseline_DTM_ESRI_102562.tif")
terra::crs(dtm)
terra::crs(dtm, describe = TRUE)
# ──────────────────────────────────────────────────────────────────────────────
# EUCVISION: DTM REPROJECTION & RESAMPLING FOR DJI FLIGHTHUB 2
# ──────────────────────────────────────────────────────────────────────────────
# Author: Jacques Vermeulen
# Project: EucVision / EucXylo (https://eucxylo.sun.ac.za/)
# ──────────────────────────────────────────────────────────────────────────────
# Description: Reprojects the baseline DTM from ESRI:102562 (Hartebeesthoek94
#              Lo19 E-N) to EPSG:4326 (WGS84) and resamples from 0.05m to 0.5m
#              resolution for upload to DJI FlightHub 2.
#
# CRS Notes: The source file carries a full WKT definition (Hartebeesthoek94,
#            Lo19 central meridian, WGS84 ellipsoid, standard E-N axis order).
#            No manual CRS override is needed — terra reads it correctly.
#            Axis order is E-N so no sign/flip correction is required.
# ──────────────────────────────────────────────────────────────────────────────
library(terra)
# ──────────────────────────────────────────────────────────────────────────────
# 1. Configuration ####
# ──────────────────────────────────────────────────────────────────────────────
input_path  <- "E:/Remote Sensing Media/00. Baseline DTM/IMPACT_OAL_Baseline_DTM_ESRI_102562.tif"
output_path <- "E:/Remote Sensing Media/00. Baseline DTM/IMPACT_OAL_Baseline_DTM_WGS84_0p5m.tif"
# Stellenbosch expected extent (used for sanity check after reprojection)
# Longitude: ~18.8–19.1°E  |  Latitude: ~34.0–34.3°S
EXPECTED_LON <- c(18.5, 19.5)
EXPECTED_LAT <- c(-34.6, -33.8)
# ──────────────────────────────────────────────────────────────────────────────
# 2. Load & Inspect Source ####
# ──────────────────────────────────────────────────────────────────────────────
cat("Loading DTM...\n")
dtm <- terra::rast(input_path)
cat("  Source CRS    :", terra::crs(dtm, describe = TRUE)$name, "\n")
cat("  Source res (m):", terra::res(dtm), "\n")
cat("  Source dims   :", terra::nrow(dtm), "rows x", terra::ncol(dtm), "cols\n")
cat("  File size     :", round(file.size(input_path) / 1e6, 1), "MB\n\n")
# ──────────────────────────────────────────────────────────────────────────────
# 3. Reproject & Resample to WGS84 @ 0.5m ####
# ──────────────────────────────────────────────────────────────────────────────
# terra::project() handles both CRS transformation and resampling in one step.
#
# Resolution: EPSG:4326 uses decimal degrees, not metres.
#   0.5m / 111,320 m-per-degree ≈ 4.49e-06 degrees
#   (111,320 is the standard equatorial approximation; the small latitude error
#    at ~34°S is negligible for flight planning purposes.)
#
# Method: bilinear is correct for continuous elevation surfaces — it
#   interpolates smoothly and avoids staircase artefacts from nearest-neighbour.
# ──────────────────────────────────────────────────────────────────────────────
cat("Reprojecting to EPSG:4326 and resampling to ~0.5m...\n")
dtm_wgs84 <- terra::project(
dtm,
"EPSG:4326",
res    = 0.5 / 111320,   # 0.5m converted to decimal degrees
method = "bilinear"
)
cat("  Target CRS        :", terra::crs(dtm_wgs84, describe = TRUE)$name, "\n")
cat("  Target res (deg)  :", terra::res(dtm_wgs84), "\n")
cat("  Target res (m est):", round(terra::res(dtm_wgs84) * 111320, 2), "m\n")
cat("  Target dims       :", terra::nrow(dtm_wgs84), "rows x", terra::ncol(dtm_wgs84), "cols\n\n")
# ──────────────────────────────────────────────────────────────────────────────
# 4. Sanity Check — Confirm Stellenbosch Coordinates ####
# ──────────────────────────────────────────────────────────────────────────────
ext_out <- terra::ext(dtm_wgs84)
lon_ok  <- ext_out$xmin >= EXPECTED_LON[1] & ext_out$xmax <= EXPECTED_LON[2]
lat_ok  <- ext_out$ymin >= EXPECTED_LAT[1] & ext_out$ymax <= EXPECTED_LAT[2]
cat("Extent check:\n")
cat("  Longitude :", round(ext_out$xmin, 5), "to", round(ext_out$xmax, 5),
ifelse(lon_ok, "[OK - within Stellenbosch range]\n", "[WARNING - outside expected range!]\n"))
cat("  Latitude  :", round(ext_out$ymin, 5), "to", round(ext_out$ymax, 5),
ifelse(lat_ok, "[OK - within Stellenbosch range]\n", "[WARNING - outside expected range!]\n"))
cat("\n")
if (!lon_ok || !lat_ok) {
stop(paste(
"Extent is outside the expected Stellenbosch bounding box.",
"Do NOT upload this file to FlightHub 2.",
"Check source CRS and re-run."
))
}
# ──────────────────────────────────────────────────────────────────────────────
# 5. Export ####
# ──────────────────────────────────────────────────────────────────────────────
cat("Writing output...\n")
terra::writeRaster(
dtm_wgs84,
filename  = output_path,
overwrite = TRUE,
gdal      = c("COMPRESS=LZW", "PREDICTOR=3")  # Lossless float compression
)
cat("  Output saved to  :", output_path, "\n")
cat("  Output file size :", round(file.size(output_path) / 1e6, 1), "MB\n\n")
cat("Done. Ready for DJI FlightHub 2 upload.\n")
