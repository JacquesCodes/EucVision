# October .las file
# Top Catalog(ctg)
ctg_top <- readLAScatalog("E:/Remote Sensing Media/7. 30 October 2025/Point cloud/Lourensford_Top_30 October_group1_densified_point_cloud.las")
# Bottom Catalog(ctg)
ctg_bottom <- readLAScatalog("E:/Remote Sensing Media/7. 30 October 2025/Point cloud/Lourensford_30 Ocotober_Bottom_group1_densified_point_cloud.las")
las_check(ctg_top)
las_check(ctg_bottom)
plot(ctg_top)
plot(ctg_bottom,add = TRUE)
plot(ctg_top)
plot(ctg_bottom)
# Multiple threads mode
plan(multisession)
# Each plot is dependent and buffers ARE needed
opt_independent_files(ctg_top) <- FALSE
opt_independent_files(ctg_bottom) <- FALSE
tic()
# Write to disk rather than memory:
opt_output_files(ctg_top) <- paste0("E:/Remote Sensing Media/0. R Projects/2. 30 October 2025/Test/", "{*}_classified")
# Ground classifications :
ctg_top_classified <- classify_ground(ctg_top, csf(sloop_smooth = TRUE, class_threshold = 0.01, cloth_resolution = 0.5, time_step = 1))
toc()
plot(ctg_top_classified)
tic()
# Write to disk rather than memory:
opt_output_files(ctg_top_classified) <- paste0("E:/Remote Sensing Media/0. R Projects/2. 30 October 2025/Test/", "{*}_normalised")
# A point cloud-based normalization without a raster:
ctg_top_normalised <- normalize_height(las = ctg_top_classified, algorithm = tin())
toc()
tic()
# Write to disk rather than memory:
opt_output_files(ctg_top_normalised) <- paste0("E:/Remote Sensing Media/0. R Projects/2. 30 October 2025/Test/", "{*}_chm")
# Rasterize canopy with interpolation:
ctg_top_chm <- rasterize_canopy(ctg_top_normalised, res = 0.01, algorithm = p2r(na.fill = tin()))
gc()
