# 1. Define file paths (Converted backslashes to forward slashes for R)
main_path <- "C:/Users/jakev/Stellenbosch University/JacquesV B.Sc. skripsie M.Sc. project - Documents/Processed Data/EucVision/01. Data analysis/04. 02 March 2026 Densifications Compared.csv"
single_4_8_path <- "E:/Remote Sensing Media/17. 02 March 2026 4.8/09. Crown Metrics/Crown_Metrics_02_March_2026_4.8.csv"
single_2_4_path <- "E:/Remote Sensing Media/17. 02 March 2026 2.4/09. Crown Metrics/Crown_Metrics_02_March_2026_2.4.csv"
single_19_2_path <- "E:/Remote Sensing Media/17. 02 March 2026 19.2/09. Crown Metrics/Crown_Metrics_02_March_2026_19.2.csv"
# 2. Read the datasets
main_df <- read_csv(main_path, show_col_types = FALSE)
