colour = "grey40", linewidth = 0.5) +
geom_point(data = sig_points,
aes(x = days, y = rug_y),
colour = "red", alpha = 0.8,
shape = 124, size = 3) +
coord_cartesian(clip = "off") +
facet_wrap(~ comparison, ncol = ncol) +
labs(x = "Days from 1 September 2025", y = y_label) +
theme_thesis()
}
