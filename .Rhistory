impact_bounds_path <- "C:/Users/jakev/Stellenbosch University/JacquesV B.Sc. skripsie M.Sc. project - Documents/Processed Data/EucVision/02. QGIS Shapefiles/4. IMPACT Plot & Compartment Boundaries/IMPACT_Plot_&_Compartment_Boundaries_ESRI_102562.shp"
# --- THE COVERAGE RESOLUTION ---
# Based on the 24cm point spacing of the Cross Hatch flights,
# 0.25m ensures a solid, continuous boolean mask without false holes.
raster_res <- 0.25
z_threshold <- 0.3
print("Loading static spatial data...")
baseline_dtm <- rast(baseline_dtm_path)
plots <- st_read(plots_shp_path, quiet = TRUE)
st_crs(plots) <- st_crs(baseline_dtm)
plots <- plots[order(plots$id), ]
impact_bounds <- st_read(impact_bounds_path, quiet = TRUE)
st_crs(impact_bounds) <- st_crs(baseline_dtm)
top_bound <- impact_bounds[grepl("TOP", impact_bounds$Name, ignore.case = TRUE), ]
bot_bound <- impact_bounds[grepl("BOTTOM", impact_bounds$Name, ignore.case = TRUE), ]
plan(multisession, workers = 6)
# Find all dates, but we will ONLY process ones that actually have the 0.6 GSD folder
folders <- list.dirs(base_dir, recursive = FALSE)
dataset_folders <- folders[grepl("^\\d{2}\\.", basename(folders))]
# ──────────────────────────────────────────────────────────────────────────────
# 2. Master Dual-Flight Loop
# ──────────────────────────────────────────────────────────────────────────────
for (folder_path in dataset_folders) {
las_folder_std <- file.path(folder_path, "03. Point Clouds")
las_folder_fine <- file.path(las_folder_std, "0.6 GSD")
# Skip dates that don't have the dual flights
if (!dir.exists(las_folder_fine)) next
date_folder <- basename(folder_path)
file_date <- sub("^\\d+\\.\\s*", "", date_folder)
file_date_safe <- gsub(" ", "_", file_date)
print(paste("================================================================"))
print(paste("RUNNING COVERAGE TEST:", date_folder))
print(paste("================================================================"))
out_dir <- file.path(folder_path, "11. Coverage Analysis")
if (!dir.exists(out_dir)) dir.create(out_dir, recursive = TRUE)
out_csv_path <- file.path(out_dir, paste0("Planar_Coverage_", file_date_safe, ".csv"))
if (file.exists(out_csv_path)) {
print("-> SKIPPED: Coverage CSV already exists.")
next
}
temp_dir <- file.path(folder_path, "TEMP_Coverage")
dir.create(temp_dir, showWarnings = FALSE)
# ────────────────────────────────────────────────────────────────────────────
# 3. Helper Function: Process a point cloud type into a Binarized Raster
# ────────────────────────────────────────────────────────────────────────────
generate_boolean_canopy <- function(las_files, name_tag) {
top_files <- las_files[grepl("Top", basename(las_files), ignore.case = TRUE)]
bot_files <- las_files[grepl("Bottom", basename(las_files), ignore.case = TRUE)]
merged_raster_path <- file.path(temp_dir, paste0(name_tag, "_Canopy.tif"))
rasters_to_merge <- list()
# Process Top
if (length(top_files) > 0) {
ctg_top <- readLAScatalog(top_files)
# FIX 2: Force the point cloud CRS to match the DTM to prevent empty extractions
st_crs(ctg_top) <- st_crs(baseline_dtm)
opt_select(ctg_top) <- "xyz"
opt_chunk_buffer(ctg_top) <- 0
# Clip to Impact Bound, Normalize, Filter Canopy, Rasterize
top_las <- clip_roi(ctg_top, top_bound)
if (!is.empty(top_las)) {
top_las <- normalize_height(top_las, baseline_dtm)
top_canopy <- filter_poi(top_las, Z > z_threshold)
if (!is.empty(top_canopy)) {
r_top <- rasterize_density(top_canopy, res = raster_res)
rasters_to_merge[[1]] <- r_top
}
}
}
# Process Bottom
if (length(bot_files) > 0) {
ctg_bot <- readLAScatalog(bot_files)
# FIX 2: Force the point cloud CRS to match the DTM
st_crs(ctg_bot) <- st_crs(baseline_dtm)
opt_select(ctg_bot) <- "xyz"
opt_chunk_buffer(ctg_bot) <- 0
bot_las <- clip_roi(ctg_bot, bot_bound)
if (!is.empty(bot_las)) {
bot_las <- normalize_height(bot_las, baseline_dtm)
bot_canopy <- filter_poi(bot_las, Z > z_threshold)
if (!is.empty(bot_canopy)) {
r_bot <- rasterize_density(bot_canopy, res = raster_res)
rasters_to_merge[[2]] <- r_bot
}
}
}
# Merge and Binarize (1 = Canopy, NA = Hole)
if (length(rasters_to_merge) > 0) {
# FIX 1: Use mosaic with 'max' to prevent NA bounding boxes from overwriting valid data
site_raster <- terra::mosaic(sprc(rasters_to_merge), fun = "max")
# Turn all point densities > 0 into a strict "1"
site_binary <- terra::ifel(site_raster > 0, 1, NA)
# Ensure final CRS is strictly attached before saving
crs(site_binary) <- crs(baseline_dtm)
terra::writeRaster(site_binary, merged_raster_path, overwrite = TRUE)
return(site_binary)
} else {
return(NULL)
}
}
# ────────────────────────────────────────────────────────────────────────────
# 4. Generate the Boolean Masks
# ────────────────────────────────────────────────────────────────────────────
print("-> Generating 3cm (Standard) Boolean Mask...")
std_files <- list.files(las_folder_std, pattern = "\\.(las|laz)$", full.names = TRUE, recursive = FALSE)
raster_3cm <- generate_boolean_canopy(std_files, "Standard_3cm")
print("-> Generating 0.6cm (Fine) Boolean Mask...")
fine_files <- list.files(las_folder_fine, pattern = "\\.(las|laz)$", full.names = TRUE, recursive = FALSE)
raster_06cm <- generate_boolean_canopy(fine_files, "Fine_06cm")
if (is.null(raster_3cm) || is.null(raster_06cm)) {
print("Error generating rasters. Skipping.")
unlink(temp_dir, recursive = TRUE)
next
}
# ────────────────────────────────────────────────────────────────────────────
# 5. The Coverage Math & Extraction
# ────────────────────────────────────────────────────────────────────────────
print("-> Calculating Sub-1cm Coverage percentages by plot...")
# Ensure the rasters completely align spatially
raster_06cm <- terra::resample(raster_06cm, raster_3cm, method = "near")
# The Cookie Cutter: Only keep 0.6cm pixels that fall INSIDE the 3cm mold
masked_06cm <- terra::ifel(raster_3cm == 1 & raster_06cm == 1, 1, NA)
# Extract the pixel counts per plot
# 'sum' adds up all the 1s inside the polygon
plots$Area_3cm_pixels <- exact_extract(raster_3cm, plots, 'sum')
plots$Area_06cm_pixels <- exact_extract(masked_06cm, plots, 'sum')
# Calculate physical square meters and percentage
pixel_area_m2 <- raster_res^2
results_df <- st_drop_geometry(plots) %>%
select(Plot_ID = id) %>%
mutate(
Plot_ID = paste0("Plot_", Plot_ID), # Clean up Plot ID formatting
Flight_Date = file_date,
Canopy_Footprint_3cm_m2 = round(Area_3cm_pixels * pixel_area_m2, 2),
Canopy_Footprint_06cm_m2 = round(Area_06cm_pixels * pixel_area_m2, 2),
Coverage_Percent = round((Canopy_Footprint_06cm_m2 / Canopy_Footprint_3cm_m2) * 100, 2)
)
write.csv(results_df, out_csv_path, row.names = FALSE)
print(paste("-> Successfully saved:", basename(out_csv_path)))
# Cleanup
unlink(temp_dir, recursive = TRUE)
rm(raster_3cm, raster_06cm, masked_06cm, results_df)
gc()
}
# ────────────────────────────────────────────────────────────────────────────
# 4. Generate the Boolean Masks
# ────────────────────────────────────────────────────────────────────────────
print("-> Generating 3cm (Standard) Boolean Mask...")
std_files <- list.files(las_folder_std, pattern = "\\.(las|laz)$", full.names = TRUE, recursive = FALSE)
raster_3cm <- generate_boolean_canopy(std_files, "Standard_3cm")
