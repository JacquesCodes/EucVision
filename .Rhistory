Boundary <- st_read("E:/Remote Sensing Media/1. QGIS Projects/IMPACT OAL boundaries/Impact Boundaries.shp")
# View trees on plots:
plot(Boundary, col = "#dfdfdf")
plot(ctg, add = TRUE)
plot(trees, add = TRUE, col = "red")
