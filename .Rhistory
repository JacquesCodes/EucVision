# Install if needed
install.packages("foreign")
install.packages("dplyr")
install.packages("dplyr")
# Load libraries
library(foreign)
library(dplyr)
# Set folder path containing your DBF files
folder_path <- "C:/Users/jakev/Stellenbosch University/JacquesV B.Sc. skripsie M.Sc. project - Documents/Processed Data/EucVision/QGIS Extracted data/1 September 2025"
# List all DBF files in the folder
dbf_files <- list.files(folder_path, pattern = "\\.dbf$", full.names = TRUE)
dbf_files
# Read and combine them
all_data <- lapply(dbf_files, function(file) {
# Extract file name without extension (e.g. "Plot 1")
file_name <- tools::file_path_sans_ext(basename(file))
# Read DBF file
df <- read.dbf(file, as.is = TRUE)
# Add the file name as first column
df <- cbind(Plot = file_name, df)
return(df)
}) %>%
bind_rows()  # Combine all data frames into one
# View or save result
View(all_data)
