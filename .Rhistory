# 1. Load your baseline point cloud catalog
baseline_ctg <- readLAScatalog("E:/Remote Sensing Media/02. 01 September 2025 (DJI M300)/03. Point clouds")
# 2. Memory and File Management
opt_chunk_size(baseline_ctg) <- 25
